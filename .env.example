# Resend API Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxx"

# Email Configuration
# The "from" email address must be from a verified domain in Resend
# This will be the sender shown in the email (e.g., "Contact Form <mail@chad.lu>")
EMAIL_FROM="your-system@email.com"
EMAIL_FROM_NAME="Contact Form"

# Contact form recipient - where you want to receive the messages
# This is YOUR email address where all contact form submissions will be sent
EMAIL_TO="your@email.com"

# Cloudflare Turnstile Configuration
# Get your keys from: https://dash.cloudflare.com/profile/api-tokens > Turnstile
# Create a new site with your domain (chad.lu) to get these keys

# Site Key (Public) - This will be visible in the frontend code
# Used to render the Turnstile widget on your contact form
TURNSTILE_SITE_KEY="0x4AAAAAAA..."

# Secret Key (Private) - Keep this secure, only used on the server
# Used to verify the Turnstile token on form submission
TURNSTILE_SECRET_KEY="0x4AAAAAAA..."