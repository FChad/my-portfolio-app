# Base URL Configuration
# The base URL of your portfolio website
BASE_URL="https://www.example.com"

# SMTP Configuration
# Connect to your mailserver via SMTP
NUXT_SMTP_HOST="mail.openxchange.eu"
NUXT_SMTP_PORT="587"
NUXT_SMTP_USER="your-smtp@email.com"
NUXT_SMTP_PASS="your-smtp-password"

# Email Configuration
# The "from" address must be a valid mailbox on your SMTP server
# This will be the sender shown in the email (e.g., "Contact Form <system@chad.lu>")
NUXT_EMAIL_FROM="your-system@email.com"
NUXT_EMAIL_FROM_NAME="Contact Form"

# Contact form recipient - where you want to receive the messages
# This is YOUR email address where all contact form submissions will be sent
NUXT_EMAIL_TO="your@email.com"

# Cloudflare Turnstile Configuration
# Get your keys from: https://dash.cloudflare.com/profile/api-tokens > Turnstile
# Create a new site with your domain (chad.lu) to get these keys

# Site Key (Public) - This will be visible in the frontend code
# Used to render the Turnstile widget on your contact form
NUXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA..."

# Secret Key (Private) - Keep this secure, only used on the server
# Used to verify the Turnstile token on form submission
NUXT_TURNSTILE_SECRET_KEY="0x4AAAAAAA..."