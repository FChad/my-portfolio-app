# Base URL Configuration
# The base URL of your portfolio website
BASE_URL="https://www.example.com"

# SMTP Configuration
# Connect to your mailserver via SMTP
NUXT_SMTP_HOST="smtp.your-mailserver.com"
NUXT_SMTP_PORT="587"
NUXT_SMTP_USER="your@email.com"
NUXT_SMTP_PASS="your-smtp-password"

# Email Configuration
# The "from" address must be a valid mailbox on your SMTP server
NUXT_EMAIL_FROM="your@email.com"
NUXT_EMAIL_FROM_NAME="Contact Form"

# Contact form recipient - where you want to receive the messages
# This is YOUR email address where all contact form submissions will be sent
NUXT_EMAIL_TO="your@email.com"
